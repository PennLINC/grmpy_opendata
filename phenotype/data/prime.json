  "prime_total_score": {
    "Description": "Sum of the first 12 PRIME Screen-Revised items (sip003 through sip014). 'n/a' if any of those 12 items is missing."
  },
  "prime_clinical_significance": {
    "Description": "Clinical significance based on the first 12 items (sip003-sip014). '1' if the participant meets any of: (a) >= 1 item rated 6, (b) >= 3 items rated 5, or (c) prime_total_score above the age-specific cutoff (participants older than 21 use the age-21 cutoff). '0' if the participant meets none of the criteria. 'n/a' if the 12 scored items are incomplete.",
    "Levels": {
      "1": "Meets at least one clinical significance criterion.",
      "0": "Meets no criterion.",
      "n/a": "Not evaluable (the 12 scored items are incomplete)."
    }
